# Environment Variables for Mood Lexicon

# 🔒 IMPORTANT: Never commit the .env file to Git!
# This file is tracked and will expose secrets.
# Use .env.local for local development instead.

# API Ninjas - Quotes API
# Get your API key from: https://api-ninjas.com
# For local development: Create .env.local with this variable
# For production (Railway): Set this in Railway dashboard Variables
REACT_APP_QUOTES_API_KEY=your_api_key_here

